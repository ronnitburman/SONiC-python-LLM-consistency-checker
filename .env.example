SONIC_CONNECTION_MODE=orb_vm_exec
SONIC_CONTAINER_NAME=clab-sonic-ai-lab-sonic1
# For OrbStack VM setups (containerlab inside Orb VM):
# SONIC_CONNECTION_MODE=orb_vm_exec
# SONIC_ORB_VM_NAME=sonic-lab

SONIC_REDIS_HOST=localhost
SONIC_REDIS_PORT=6379

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── LLM Provider (Step 7) ────────────────────────────────────────────
# deepseek: cloud API (needs DEEPSEEK_API_KEY)
# ollama:   local models (needs ollama running)
LLM_PROVIDER=deepseek

# DeepSeek
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Ollama (local)
# ChatOllama uses Ollama's native API — base_url should NOT include /v1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:4b-mlx

# LLM temperature (0.0–1.0, lower = more deterministic)
LLM_TEMPERATURE=0.0

# MCP Server URL (for agent tool bridge)
SONIC_MCP_URL=http://127.0.0.1:9100/mcp
